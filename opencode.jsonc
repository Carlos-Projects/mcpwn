{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "build": {
      "tools": {
        "skill": true
      }
    }
  },

  "command": {
    "test": {
      "template": "Run `python -m pytest tests/ -v` and report results.",
      "description": "Run MCPwn tests"
    },
    "survey": {
      "template": "Run `python -m mcpwn survey --url <url>` to survey an MCP server.",
      "description": "Survey an MCP server"
    },
    "lab": {
      "template": "Start the vulnerable lab server with `python -m mcpwn lab --http --port 8080`.",
      "description": "Start vulnerable MCP lab"
    },
    "demo": {
      "template": "Run `python -m mcpwn demo` to run the automated demo.",
      "description": "Run MCPwn demo"
    }
  }
}
